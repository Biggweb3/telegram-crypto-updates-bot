# Telegram
TELEGRAM_BOT_TOKEN=

# MongoDB (required for this bot)
MONGODB_URI=

# CookMyBots X Proxy (required to actually poll X)
COOKMYBOTS_X_ENDPOINT=
COOKMYBOTS_X_KEY=

# Admins (comma-separated Telegram user IDs)
ADMIN_TELEGRAM_USER_IDS=

# Optional polling interval (seconds). Default: 120
POLL_INTERVAL_SECONDS=120
